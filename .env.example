# MarshTech - Environment Variables Template
# Copy this file to '.env' and fill in your real values.

# [REQUIRED] Groq API Key for Device Description Generation
# Obtain one from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# [OPTIONAL] JWT Secret Key for Authentication
# A default value is provided in docker-compose.yml for easy local testing.
# Override this in production for enhanced security.
JWT_SECRET_KEY=MarshTech-Development-Secret-Key-2026-ChangeInProd!
